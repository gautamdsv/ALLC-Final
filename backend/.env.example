# Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase pooler URL (used at runtime via PgBouncer — port 6543)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public&sslmode=require"

# Supabase direct URL (used by Prisma Studio / migrate — port 5432)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public&sslmode=require"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
CORS_ORIGIN="http://localhost:5173"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
REFRESH_TOKEN_SECRET="CHANGE_ME_TO_A_DIFFERENT_LONG_RANDOM_STRING"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=7

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key from resend.com
# Domain must be verified at resend.com/domains before emails are delivered
RESEND_API_KEY="re_YOUR_API_KEY"
RESEND_FROM_EMAIL="ALLC Clinic <noreply@asianllc.com>"

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used in password reset links sent via email
FRONTEND_URL="http://localhost:5173"

# ── Notifications ─────────────────────────────────────────────────────────────
# Email that receives a notification on every new waitlist submission
# Leave blank to disable clinic notifications
CLINIC_NOTIFY_EMAIL="contact@asianllc.com"
